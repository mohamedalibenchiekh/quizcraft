# ─── Server ──────────────────────────────────────────────
PORT=5000

# ─── MongoDB Atlas ───────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/quizcraft?retryWrites=true&w=majority

# ─── JWT ─────────────────────────────────────────────────
JWT_SECRET=replace_with_a_strong_random_secret
JWT_EXPIRES_IN=7d

# ─── CORS (set to your frontend URL — localhost for dev, Vercel URL for prod) ─
CLIENT_URL=http://localhost:5173

# ─── AI Service ──────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here


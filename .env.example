# MongoDB Atlas connection string placeholder
# Replace the host, username, password, and database name with your own values.
MONGO_URI=mongodb+srv://<dbUser>:<dbPassword>@cluster0.xxxx.mongodb.net/quizcraft?retryWrites=true&w=majority

# JSON Web Token signing secret placeholder
# Use a strong random string in production for token integrity and confidentiality.
JWT_SECRET=YOUR_SECURE_JWT_SECRET_HERE

# OpenAI API key placeholder
# Store your OpenAI key securely and never commit the real value to source control.
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Frontend API base URL placeholder
# Configure the client to point at the backend API endpoint used during local development or deployment.
VITE_API_URL=http://localhost:5000

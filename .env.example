# ─── DATABASE CONFIGURATION ──────────────────────────────
# MongoDB Atlas production connection string
MONGO_URI=your_production_mongodb_connection_string

# ─── SECURITY CONFIGURATION ──────────────────────────────
# Long, secure production JWT random hash
JWT_SECRET=your_long_secure_production_jwt_random_hash

# ─── NETWORKING CONFIGURATION ────────────────────────────
# Public/Live URL of your React production frontend (for CORS dynamic whitelisting)
CLIENT_URL=https://your-quizcraft-frontend-url.com

# Port allocated by the cloud service provider (defaults to 5000)
PORT=5000

# ─── AI LAYER CONFIGURATION ──────────────────────────────
# OpenAI API key for auto-question generation service
OPENAI_API_KEY=your_production_openai_api_key_here
